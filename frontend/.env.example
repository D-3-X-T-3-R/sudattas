# GraphQL API (Next.js embeds NEXT_PUBLIC_* at build time)
# Default: http://localhost:8080/v2
NEXT_PUBLIC_GRAPHQL_URL=

# Optional: fixed token or session for dev (overrides guest session when set)
# NEXT_PUBLIC_GRAPHQL_TOKEN=
# NEXT_PUBLIC_GRAPHQL_SESSION_ID=

# Admin panel — optional static key; when using Google login, Bearer token is sent instead
# NEXT_PUBLIC_ADMIN_API_KEY=

# Google OAuth (NextAuth) — required for admin panel /imtheboss
# Generate AUTH_SECRET: npx auth secret  (or openssl rand -base64 32)
# AUTH_SECRET=
# NEXTAUTH_URL=http://localhost:3000   # Production: your app URL
# GOOGLE_CLIENT_ID=     # From Google Cloud Console OAuth 2.0 Client
# GOOGLE_CLIENT_SECRET=
# In Google Console, add redirect URI: http://localhost:3000/api/auth/callback/google
# Restrict admin to specific Google accounts (comma-separated emails). If unset, any Google user can sign in.
# ADMIN_ALLOWED_EMAILS=admin@example.com,other@example.com
