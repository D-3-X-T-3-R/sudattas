# GraphQL API (Next.js embeds NEXT_PUBLIC_* at build time)
# Default: http://localhost:8080/v2
NEXT_PUBLIC_GRAPHQL_URL=

# Optional: fixed token or session for dev (overrides guest session / Auth0 when set)
# NEXT_PUBLIC_GRAPHQL_TOKEN=
# NEXT_PUBLIC_GRAPHQL_SESSION_ID=

# Admin panel (/admin) — set to match backend ADMIN_API_KEY for GraphQL admin mutations
# NEXT_PUBLIC_ADMIN_API_KEY=

# Auth0 (optional — when set, login/logout can be wired and JWT is sent for API calls)
# NEXT_PUBLIC_AUTH0_DOMAIN=your-tenant.auth0.com
# NEXT_PUBLIC_AUTH0_CLIENT_ID=your_client_id
# NEXT_PUBLIC_AUTH0_AUDIENCE=           # Match backend OAUTH_AUDIENCE
# NEXT_PUBLIC_AUTH0_REDIRECT_URI=      # Default: window.location.origin
